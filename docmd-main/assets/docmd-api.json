{
  "openapi": "3.0.0",
  "info": {
    "title": "docmd Plugin API",
    "version": "1.0.0",
    "description": "The official OpenAPI spec for docmd plugin developers. Use this to integrate docmd with your AI tools or custom build systems."
  },
  "paths": {
    "/hooks": {
      "get": {
        "summary": "List available hooks",
        "description": "Returns a list of all lifecycle hooks available for plugins.",
        "responses": {
          "200": {
            "description": "A list of hooks",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/render": {
      "post": {
        "summary": "Render markdown",
        "description": "Triggers the rendering engine for a specific markdown string.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "content": { "type": "string" },
                  "context": { "type": "object" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Rendered HTML",
            "content": {
              "text/html": {
                "schema": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}