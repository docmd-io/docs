{
  "title": "docmd docs",
  "url": "https://docs.docmd.io",
  "src": ".",

  "logo": {
    "light": "assets/images/docmd-logo-dark.png",
    "dark": "assets/images/docmd-logo-light.png",
    "alt": "docmd Logo",
    "href": "https://docmd.io"
  },
  "favicon": "assets/favicon.ico",

  "minify": true,
  "autoTitleFromH1": true,
  "copyCode": true,
  "pageNavigation": true,

  "customJs": [
    "/assets/js/theme-switcher.js"
  ],

  "theme": {
    "name": "default",
    "appearance": "light",
    "codeHighlight": true,
    "customCss": [
      "/assets/css/threads-preview.css"
    ]
  },

  "layout": {
    "spa": true,
    "breadcrumbs": true,
    "menubar": {
      "enabled": false,
      "position": "top"
    },
    "header": {
      "enabled": true
    },
    "sidebar": {
      "collapsible": true,
      "defaultCollapsed": false
    },
    "optionsMenu": {
      "position": "header",
      "components": {
        "search": true,
        "themeSwitch": true,
        "sponsor": "https://github.com/sponsors/mgks"
      }
    },
    "footer": {
      "style": "complete",
      "description": "Build production-ready documentation from Markdown in seconds.",
      "copyright": "© 2025-present docmd.io",
      "columns": [
        {
          "title": "Resources",
          "links": [
            { "text": "Installation", "url": "/getting-started/installation" },
            { "text": "Configuration", "url": "/configuration/general" },
            { "text": "CLI Commands", "url": "/api/cli-commands" }
          ]
        },
        {
          "title": "Ecosystem",
          "links": [
            { "text": "Versioning", "url": "/configuration/versioning" },
            { "text": "Plugins", "url": "/plugins/usage" },
            { "text": "Themes", "url": "/theming/customisation" },
            { "text": "Live Editor", "url": "/content/live-preview" }
          ]
        },
        {
          "title": "Community",
          "links": [
            { "text": "GitHub", "url": "https://github.com/docmd-io/docmd", "external": true },
            { "text": "Discussions", "url": "https://github.com/orgs/docmd-io/discussions", "external": true },
            { "text": "Contributing", "url": "/contributing" },
            { "text": "Reports & Issues", "url": "https://github.com/docmd-io/docmd/issues", "external": true }
          ]
        }
      ]
    }
  },

  "plugins": {
    "seo": {
      "defaultDescription": "Build production-ready documentation from Markdown in seconds. Zero setup, fast by default, SEO-friendly, and AI-ready.",
      "aiBots": true,
      "openGraph": { "defaultImage": "assets/images/docmd-preview-en.webp" },
      "twitter": { "cardType": "summary_large_image" }
    },
    "analytics": { "googleV4": { "measurementId": "G-YGLJ5HPMM3" } },
    "math": {},
    "git": {
      "repo": "https://github.com/docmd-io/docs",
      "branch": "main",
      "maxCommits": 4
    }
  },

  "i18n": {
    "default": "en",
    "position": "sidebar-top",
    "locales": [
      { "id": "en", "label": "English", "dir": "ltr" },
      { "id": "zh", "label": "中文", "dir": "ltr",
        "translations": {
          "Resources": "资源",
          "Ecosystem": "生态",
          "Community": "社区",
          "Installation": "安装",
          "Configuration": "配置",
          "CLI Commands": "CLI 命令",
          "Versioning": "版本管理",
          "Plugins": "插件",
          "Themes": "主题",
          "Live Editor": "实时编辑器",
          "Discussions": "讨论区",
          "Contributing": "贡献指南",
          "Reports & Issues": "问题反馈"
        }
      },
      { "id": "de", "label": "Deutsch", "dir": "ltr",
        "translations": {
          "Resources": "Ressourcen",
          "Ecosystem": "Ökosystem",
          "Community": "Community",
          "Installation": "Installation",
          "Configuration": "Konfiguration",
          "CLI Commands": "CLI-Befehle",
          "Versioning": "Versionierung",
          "Plugins": "Plugins",
          "Themes": "Themen",
          "Live Editor": "Live-Editor",
          "Discussions": "Diskussionen",
          "Contributing": "Mitwirken",
          "Reports & Issues": "Fehler melden"
        }
      }
    ]
  },

  "versions": {
    "current": "08",
    "position": "sidebar-top",
    "all": [
      { "id": "08", "dir": "v08", "label": "v0.8.0" },
      { "id": "07", "dir": "v07", "label": "v0.7.0" },
      { "id": "06", "dir": "v06", "label": "v0.6.0" },
      { "id": "05", "dir": "v05", "label": "v0.5.0" },
      { "id": "04", "dir": "v04", "label": "v0.4.0" }
    ]
  }
}