{
  "name": "docmd.io",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "docmd dev",
    "dev:local": "node ../docmd/packages/core/dist/bin/docmd.js dev",
    "dev:sim": "node ../docmd/tools/sim.mjs --source=. --regen-tars --dev --skip-monorepo-build",
    "build": "docmd build",
    "build:local": "node ../docmd/packages/core/dist/bin/docmd.js build",
    "build:sim": "node ../docmd/tools/sim.mjs --source=. --regen-tars --build --skip-monorepo-build",
    "doctor:local": "node ../docmd/packages/core/dist/bin/docmd.js doctor",
    "doctor:sim": "node ../docmd/tools/sim.mjs --source=. --regen-tars --doctor --skip-monorepo-build",
    "preview": "npx serve site"
  },
  "dependencies": {
    "@docmd/core": "^0.8.15",
    "@docmd/plugin-search": "^0.8.15",
    "@huggingface/transformers": "^4.2.0",
    "docmd-search": "^0.1.1",
    "onnxruntime-node": "^1.27.0"
  },
  "allowScripts": {
    "@docmd/engine-rust": true,
    "esbuild": true,
    "onnxruntime-node": true,
    "protobufjs": true,
    "sharp": true
  }
}
